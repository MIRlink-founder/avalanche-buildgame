{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "jsx": "preserve",
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@mire/database": ["../../packages/database/src/index.ts"],
      "@mire/blockchain": ["../../packages/blockchain/src/index.ts"],
      "@mire/blockchain/*": ["../../packages/blockchain/src/*"],
      "@mire/ui": ["../../packages/ui/src/index.ts"],
      "@mire/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "app/**/*.js",
    "app/**/*.jsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "auth.ts",
    "proxy.ts",
    "env.d.ts",
    "../../packages/database/src/**/*.ts",
    "../../packages/blockchain/src/**/*.ts",
    "../../packages/blockchain/src/**/*.tsx",
    "../../packages/ui/src/**/*.ts",
    "../../packages/ui/src/**/*.tsx",
    "next-env.d.ts"
  ],
  "exclude": ["out-tsc", "dist", "node_modules", ".next"],
  "references": [
    {
      "path": "../../packages/ui"
    },
    {
      "path": "../../packages/database"
    },
    {
      "path": "../../packages/blockchain"
    }
  ]
}
